{
  "name": "wdio-agent-service",
  "repository": {
    "type": "git",
    "url": "git://github.com/Winify/wdio-agent-service.git"
  },
  "version": "0.2.0",
  "author": "Vince Graics",
  "description": "WebdriverIO plugin for agentic browser actions. Integrates into codebase/ecosystem.",
  "keywords": [
    "wdio-plugin",
    "wdio-service",
    "webdriverio",
    "agent",
    "testing",
    "ai",
    "ollama"
  ],
  "type": "module",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --fix && tsc --noEmit",
    "build": "rimraf build && tsup",
    "postbuild": "npm pack",
    "prepare": "husky",
    "test:examples": "pnpm run build && cd examples && pnpm i && pnpm test",
    "test:examples-mobile": "pnpm run build && cd examples && pnpm i && pnpm test:mobile",
    "release": "release-it"
  },
  "license": "MIT",
  "dependencies": {
    "@types/node": "^24.0.0",
    "@wdio/logger": "^9.18.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@wdio/elements": "^1.1.1",
    "@wdio/eslint": "^0.1.3",
    "@wdio/globals": "^9.23.0",
    "@wdio/types": "^9.23.2",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "release-it": "^20.2.1",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.0.18",
    "webdriverio": "^9.23.2"
  },
  "peerDependencies": {
    "@wdio/elements": "^1.1.1",
    "@wdio/globals": ">=9.0.0",
    "@wdio/types": ">=9.0.0",
    "webdriverio": ">=9.0.0"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  }
}
